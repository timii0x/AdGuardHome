#!/bin/sh

# One-command helper for "mostly original AGH + TTL 10% pre-expiry refresh".
#
# Commands:
#   forkadguardhome update
#   forkadguardhome reinstall
#   forkadguardhome delete
#
# Notes:
# - update/reinstall: build from upstream source + apply ONLY TTL-10% patch.
# - delete: restore official binary via upstream install script.

set -eu

REPO_URL="${FORK_AGH_REPO_URL:-https://github.com/AdguardTeam/AdGuardHome.git}"
REPO_BRANCH="${FORK_AGH_REPO_BRANCH:-master}"
SOURCE_DIR="${FORK_AGH_SOURCE_DIR:-/usr/local/src/adguardhome-src}"
INSTALL_DIR="${FORK_AGH_INSTALL_DIR:-/opt/AdGuardHome}"
SERVICE_NAME="${FORK_AGH_SERVICE_NAME:-AdGuardHome}"
KEEP_SOURCE_ON_DELETE="${FORK_AGH_KEEP_SOURCE_ON_DELETE:-0}"

log() {
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"
}

fail() {
    log "ERROR: $*"
    exit 1
}

require_root() {
    [ "$(id -u)" -eq 0 ] || fail "Run as root (sudo)."
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

install_missing_dependencies() {
    missing=""
    for tool in git make go npm curl install systemctl mktemp; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            missing="$missing $tool"
        fi
    done

    missing="${missing# }"
    [ -z "$missing" ] && return 0

    log "Installing missing dependencies:$missing"

    if command -v apt-get >/dev/null 2>&1; then
        export DEBIAN_FRONTEND=noninteractive
        apt-get update
        apt-get install -y git make golang-go nodejs npm curl ca-certificates

        return 0
    fi

    if command -v dnf >/dev/null 2>&1; then
        dnf install -y git make golang nodejs npm curl ca-certificates

        return 0
    fi

    if command -v yum >/dev/null 2>&1; then
        yum install -y git make golang nodejs npm curl ca-certificates

        return 0
    fi

    if command -v apk >/dev/null 2>&1; then
        apk add --no-cache git make go nodejs npm curl ca-certificates

        return 0
    fi

    fail "Unsupported package manager. Install manually: git make go npm curl."
}

clone_or_update_source() {
    if [ ! -d "$SOURCE_DIR/.git" ]; then
        log "Cloning $REPO_URL -> $SOURCE_DIR"
        mkdir -p "$(dirname "$SOURCE_DIR")"
        git clone --branch "$REPO_BRANCH" "$REPO_URL" "$SOURCE_DIR"

        return 0
    fi

    log "Updating source in $SOURCE_DIR"
    git -C "$SOURCE_DIR" fetch origin "$REPO_BRANCH"
    git -C "$SOURCE_DIR" checkout "$REPO_BRANCH"
    git -C "$SOURCE_DIR" pull --ff-only origin "$REPO_BRANCH"
}

is_ttl_patch_applied() {
    grep -q 'defaultPrefetchTTLRefreshPercent' "$SOURCE_DIR/internal/dnsforward/cacheprefetch.go" &&
        grep -q 'recordOptimisticPrefetchHitLocked(host, qt, pctx.Res)' "$SOURCE_DIR/internal/dnsforward/stats.go"
}

apply_ttl10_patch() {
    if is_ttl_patch_applied; then
        log "TTL 10% patch already applied."

        return 0
    fi

    tmp_patch="$(mktemp)"
    trap 'rm -f "$tmp_patch"' EXIT

    cat >"$tmp_patch" <<'PATCH'
diff --git a/internal/dnsforward/cacheprefetch.go b/internal/dnsforward/cacheprefetch.go
index f2c1e067..4820ae5d 100644
--- a/internal/dnsforward/cacheprefetch.go
+++ b/internal/dnsforward/cacheprefetch.go
@@ -22,6 +22,7 @@ const (
 )
 
 const defaultPrefetchKeepDays uint32 = 5
+const defaultPrefetchTTLRefreshPercent uint32 = 10
 
 func isValidPrefetchKeepDays(days uint32) (ok bool) {
 	switch days {
@@ -64,6 +65,7 @@ func isValidPrefetchMode(mode cacheOptimisticPrefetchMode) (ok bool) {
 type prefetchHostStats struct {
 	lastSeen     time.Time
 	lastPrefetch time.Time
+	nextPrefetch time.Time
 	hourStart    time.Time
 	hitsInHour   uint32
 	wantA        bool
@@ -182,6 +184,10 @@ func (s *Server) collectPrefetchTargets(
 			continue
 		}
 
+		if !stats.nextPrefetch.IsZero() && now.Before(stats.nextPrefetch) {
+			continue
+		}
+
 		if !stats.isEligible(mode, hourStart) {
 			continue
 		}
@@ -234,6 +240,8 @@ func (s *Server) prefetchResolve(ctx context.Context, prx *proxy.Proxy, host str
 			err,
 		)
 	}
+
+	s.updateOptimisticPrefetchTTL(host, qtype, pctx.Res, time.Now())
 }
 
 func (st *prefetchHostStats) isEligible(
@@ -254,7 +262,7 @@ func (st *prefetchHostStats) isEligible(
 
 // recordOptimisticPrefetchHitLocked records a domain hit for threshold-based
 // optimistic prefetching.  s.serverLock is expected to be locked.
-func (s *Server) recordOptimisticPrefetchHitLocked(host string, qtype uint16) {
+func (s *Server) recordOptimisticPrefetchHitLocked(host string, qtype uint16, resp *dns.Msg) {
 	mode := normalizePrefetchMode(s.conf.CacheOptimisticPrefetchMode)
 	if !s.conf.CacheEnabled || !s.conf.CacheOptimistic || mode == cacheOptimisticPrefetchModeDisabled {
 		return
@@ -296,6 +304,86 @@ func (s *Server) recordOptimisticPrefetchHitLocked(host string, qtype uint16) {
 	st.lastSeen = now
 	st.wantA = st.wantA || qtype == dns.TypeA
 	st.wantAAAA = st.wantAAAA || qtype == dns.TypeAAAA
+	st.setTTLRefreshSchedule(now, ttlFromResponse(resp, qtype))
+}
+
+// updateOptimisticPrefetchTTL updates cached TTL schedule for prefetch entries.
+// It's used to keep background prefetch cadence aligned with current response
+// TTL values.
+func (s *Server) updateOptimisticPrefetchTTL(
+	host string,
+	qtype uint16,
+	resp *dns.Msg,
+	now time.Time,
+) {
+	if host == "" {
+		return
+	}
+
+	switch qtype {
+	case dns.TypeA, dns.TypeAAAA:
+	default:
+		return
+	}
+
+	ttl := ttlFromResponse(resp, qtype)
+	if ttl <= 0 {
+		return
+	}
+
+	s.prefetchLock.Lock()
+	defer s.prefetchLock.Unlock()
+
+	st, ok := s.prefetchHosts[host]
+	if !ok {
+		return
+	}
+
+	st.setTTLRefreshSchedule(now, ttl)
+}
+
+func (st *prefetchHostStats) setTTLRefreshSchedule(now time.Time, ttl time.Duration) {
+	if ttl <= 0 {
+		return
+	}
+
+	refreshWindow := ttl * time.Duration(defaultPrefetchTTLRefreshPercent) / 100
+	if refreshWindow == 0 && ttl > time.Second {
+		refreshWindow = time.Second
+	}
+
+	next := now.Add(ttl - refreshWindow)
+	if !st.nextPrefetch.IsZero() && now.Before(st.nextPrefetch) && next.After(st.nextPrefetch) {
+		return
+	}
+
+	st.nextPrefetch = next
+}
+
+func ttlFromResponse(resp *dns.Msg, qtype uint16) (ttl time.Duration) {
+	if resp == nil {
+		return 0
+	}
+
+	found := false
+	var ttlSec uint32
+	for _, rr := range resp.Answer {
+		hdr := rr.Header()
+		if hdr == nil || hdr.Rrtype != qtype {
+			continue
+		}
+
+		if !found || hdr.Ttl < ttlSec {
+			found = true
+			ttlSec = hdr.Ttl
+		}
+	}
+
+	if !found {
+		return 0
+	}
+
+	return time.Duration(ttlSec) * time.Second
 }
 
 func (req *jsonDNSConfig) checkCachePrefetchMode() (err error) {
diff --git a/internal/dnsforward/stats.go b/internal/dnsforward/stats.go
index 700be41b..a78ba6ac 100644
--- a/internal/dnsforward/stats.go
+++ b/internal/dnsforward/stats.go
@@ -44,7 +44,7 @@ func (s *Server) processQueryLogsAndStats(ctx context.Context, dctx *dnsContext)
 	s.serverLock.RLock()
 	defer s.serverLock.RUnlock()
 
-	s.recordOptimisticPrefetchHitLocked(host, qt)
+	s.recordOptimisticPrefetchHitLocked(host, qt, pctx.Res)
 
 	if s.shouldLog(host, qt, cl, ids) {
 		s.logQuery(dctx, ip, processingTime)
PATCH

    log "Applying TTL 10% patch ..."
    git -C "$SOURCE_DIR" apply --3way "$tmp_patch" || fail "Patch apply failed."
}

build_and_install_binary() {
    log "Building AdGuard Home ..."
    make -C "$SOURCE_DIR" build
    [ -x "$SOURCE_DIR/AdGuardHome" ] || fail "Build finished but binary missing."

    mkdir -p "$INSTALL_DIR"
    install -m 0755 "$SOURCE_DIR/AdGuardHome" "$INSTALL_DIR/AdGuardHome"

    if systemctl cat "$SERVICE_NAME" >/dev/null 2>&1; then
        systemctl restart "$SERVICE_NAME"
    else
        "$INSTALL_DIR/AdGuardHome" -s install || true
        systemctl enable --now "$SERVICE_NAME"
    fi

    systemctl is-active --quiet "$SERVICE_NAME" || fail "Service is not active."
    log "Installed and restarted $SERVICE_NAME successfully."
}

cmd_update() {
    require_root
    install_missing_dependencies
    clone_or_update_source
    apply_ttl10_patch
    build_and_install_binary
}

cmd_reinstall() {
    require_root
    install_missing_dependencies

    log "Reinstall requested. Cleaning source dir: $SOURCE_DIR"
    rm -rf "$SOURCE_DIR"

    clone_or_update_source
    apply_ttl10_patch
    build_and_install_binary
}

cmd_delete() {
    require_root
    install_missing_dependencies

    log "Restoring official AdGuard Home binary ..."
    curl -s -S -L https://raw.githubusercontent.com/AdguardTeam/AdGuardHome/master/scripts/install.sh |
        sh -s -- -r -v

    if [ "$KEEP_SOURCE_ON_DELETE" != "1" ] && [ -d "$SOURCE_DIR" ]; then
        log "Removing custom source directory: $SOURCE_DIR"
        rm -rf "$SOURCE_DIR"
    fi

    log "Done. AGH is back to official installer-managed binary."
}

usage() {
    cat <<EOF
Usage:
  forkadguardhome update
  forkadguardhome reinstall
  forkadguardhome delete

Environment (optional):
  FORK_AGH_REPO_URL                  default: https://github.com/AdguardTeam/AdGuardHome.git
  FORK_AGH_REPO_BRANCH               default: master
  FORK_AGH_SOURCE_DIR                default: /usr/local/src/adguardhome-src
  FORK_AGH_INSTALL_DIR               default: /opt/AdGuardHome
  FORK_AGH_SERVICE_NAME              default: AdGuardHome
  FORK_AGH_KEEP_SOURCE_ON_DELETE     1=keep source directory after delete
EOF
}

main() {
    cmd="${1:-}"

    case "$cmd" in
        update)
            cmd_update
            ;;
        reinstall)
            cmd_reinstall
            ;;
        delete)
            cmd_delete
            ;;
        *)
            usage
            exit 1
            ;;
    esac
}

main "$@"
